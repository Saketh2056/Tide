<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="ink">#0A0D14</color>
    <color name="mint">#5EEAD4</color>
    <color name="violet">#8B7CF6</color>
    <string name="accessibility_service_description">Tide uses this service to know which app is on screen so it can gently pause distracting apps when a shield, schedule, or focus session is active. Tide never reads your screen content, collects data, or sends anything off your device.</string>
    <string name="accessibility_service_label">Tide Guardian</string>
    <string name="app_name">Tide</string>
    <style name="Theme.Tide" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/ink</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="Theme.Tide.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ink</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenAnimationDuration">450</item>
        <item name="postSplashScreenTheme">@style/Theme.Tide</item>
    </style>
</resources>